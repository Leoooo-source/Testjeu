<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Les Profondeurs</title>
<style>
body {
    margin:0;
    font-family:Arial, sans-serif;
    background:#0c0c12;
    color:#e6e6e6;
}
.container {
    max-width:600px;
    margin:auto;
    padding:15px;
}
h1 { text-align:center; }
.panel {
    background:#181822;
    padding:10px;
    border-radius:8px;
    margin-bottom:10px;
}
.log {
    height:220px;
    overflow-y:auto;
    font-size:14px;
}
button, select {
    width:100%;
    padding:12px;
    margin-top:5px;
    background:#2b2b3c;
    color:white;
    border:none;
    border-radius:6px;
    font-size:15px;
}
button:active { background:#3d3d55; }
.small { font-size:13px; opacity:0.8; }
</style>
</head>
<body>

<div class="container">
<h1>Les Profondeurs</h1>

<div class="panel">
Classe:
<select id="classSelect">
<option value="warrior">Guerrier</option>
<option value="rogue">Voleur</option>
<option value="mage">Mystique</option>
</select>
<button onclick="startGame()">Commencer / Charger</button>
</div>

<div class="panel small">
PV: <span id="hp"></span> |
ATK: <span id="atk"></span> |
DEF: <span id="def"></span> |
Chance: <span id="luck"></span> |
Salle: <span id="room"></span>
</div>

<div class="panel log" id="log"></div>

<button onclick="nextRoom()">Explorer</button>
<button onclick="attack()" id="attackBtn" style="display:none;">Attaquer</button>
<button onclick="usePotion()">Utiliser Potion</button>
<button onclick="resetGame()">Reset</button>

<div class="panel small">
Inventaire: <span id="inventory"></span>
</div>

</div>

<script>
let player = null;
let enemy = null;

function log(text){
    const l=document.getElementById("log");
    l.innerHTML+=text+"<br>";
    l.scrollTop=l.scrollHeight;
}

function roll(min,max){
    return Math.floor(Math.random()*(max-min+1))+min;
}

function save(){
    localStorage.setItem("roguelikeSave", JSON.stringify(player));
}

function load(){
    const data=localStorage.getItem("roguelikeSave");
    if(data){
        player=JSON.parse(data);
        log("Sauvegarde chargée.");
        update();
        return true;
    }
    return false;
}

function startGame(){
    if(load()) return;

    const c=document.getElementById("classSelect").value;

    if(c==="warrior"){
        player={hp:20, atk:3, def:2, luck:1, room:0, inv:[]};
    }
    if(c==="rogue"){
        player={hp:16, atk:2, def:1, luck:3, room:0, inv:[]};
    }
    if(c==="mage"){
        player={hp:14, atk:4, def:0, luck:2, room:0, inv:[]};
    }

    log("Vous entrez dans les profondeurs.");
    update();
    save();
}

function update(){
    if(!player) return;
    document.getElementById("hp").textContent=player.hp;
    document.getElementById("atk").textContent=player.atk;
    document.getElementById("def").textContent=player.def;
    document.getElementById("luck").textContent=player.luck;
    document.getElementById("room").textContent=player.room;
    document.getElementById("inventory").textContent=player.inv.join(", ");
}

function nextRoom(){
    if(!player || player.hp<=0) return;

    player.room++;

    if(player.room%5===0){
        spawnBoss();
    } else {
        let type=roll(1,5);
        if(type===1) spawnMonster();
        else if(type===2) trap();
        else if(type===3) chest();
        else if(type===4) event();
        else log("Salle vide. Un silence oppressant.");
    }

    update();
    save();
}

function spawnMonster(){
    enemy={hp:roll(8,15), atk:roll(1,4)};
    log("Un monstre surgit ! PV: "+enemy.hp);
    document.getElementById("attackBtn").style.display="block";
}

function spawnBoss(){
    enemy={hp:25+player.room, atk:5};
    log("BOSS — Abomination des Profondeurs !");
    document.getElementById("attackBtn").style.display="block";
}

function attack(){
    if(!enemy) return;

    let r=roll(1,6);
    let dmg=r+player.atk;

    if(r===6) dmg*=2;
    if(r===1) dmg=0;

    enemy.hp-=dmg;
    log("Vous infligez "+dmg+" dégâts.");

    if(enemy.hp<=0){
        log("Ennemi vaincu.");
        enemy=null;
        document.getElementById("attackBtn").style.display="none";
        loot();
        save();
        return;
    }

    let er=roll(1,6);
    let edmg=Math.max(0, er+enemy.atk-player.def);
    player.hp-=edmg;
    log("Vous subissez "+edmg+" dégâts.");

    if(player.hp<=0){
        log("Vous êtes mort. Fin définitive.");
        localStorage.removeItem("roguelikeSave");
        document.getElementById("attackBtn").style.display="none";
    }

    update();
    save();
}

function trap(){
    let dmg=roll(3,8);
    player.hp-=dmg;
    log("Un piège vous blesse. -"+dmg+" PV.");
}

function chest(){
    if(player.inv.length>=4){
        log("Coffre trouvé mais inventaire plein.");
        return;
    }

    let r=roll(1,3);
    if(r===1){ player.inv.push("Potion"); log("Potion obtenue."); }
    if(r===2){ player.atk++; log("+1 Attaque."); }
    if(r===3){ player.def++; log("+1 Défense."); }
}

function event(){
    let r=roll(1,3);
    if(r===1){
        log("Autel ancien. Vous gagnez 1 chance.");
        player.luck++;
    }
    if(r===2){
        log("Vision troublante. -2 PV.");
        player.hp-=2;
    }
    if(r===3){
        log("Fontaine obscure. +3 PV.");
        player.hp+=3;
    }
}

function loot(){
    if(player.inv.length<4 && roll(1,2)===1){
        player.inv.push("Potion");
        log("Une potion tombe au sol.");
    }
}

function usePotion(){
    let index=player.inv.indexOf("Potion");
    if(index>-1){
        player.inv.splice(index,1);
        player.hp+=6;
        log("Potion utilisée. +6 PV.");
        update();
        save();
    } else {
        log("Aucune potion.");
    }
}

function resetGame(){
    localStorage.removeItem("roguelikeSave");
    location.reload();
}
</script>

</body>
</html>
